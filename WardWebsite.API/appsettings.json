{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=.;Database=WardWebsite;Trusted_Connection=true;Encrypt=false;TrustServerCertificate=true;"
  },
  "Jwt": {
    "Secret": "your-super-secret-key-at-least-32-characters-long-for-hs256",
    "Issuer": "WardWebsite",
    "Audience": "WardWebsiteUsers"
  },
  "Swagger": {
    "Enabled": true
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://127.0.0.1:5173",
      "http://localhost:4173",
      "http://127.0.0.1:4173"
    ]
  },
  "Security": {
    "RequireHttps": false,
    "SeedDefaultUsers": true,
    "DefaultUsers": {
      "AdminPassword": "admin123",
      "EditorPassword": "editor123",
      "ViewerPassword": "viewer123"
    }
  },
  "AvatarStorage": {
    "Provider": "Local",
    "LocalBaseUrl": "",
    "AzureBlob": {
      "ConnectionString": "",
      "ContainerName": "avatars",
      "PathPrefix": "avatars"
    }
  }
}
